# ─── Application ──────────────────────────────────────────────
# Must match how you open the app in the browser (localhost vs 127.0.0.1 differ for cookies).
APP_BASE_URL=http://localhost:3000
LANDING_PAGE=/dashboard
PORTAL_UI_PALETTE=indigo
PORTAL_UI_DENSITY=compressed
UI_KIT_DRIFT_VISIBILITY=off

LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info

# Local-only: if APP_BASE_URL is https but you test on http://localhost, or Safari drops Secure cookies, set:
# SESSION_COOKIE_INSECURE=true

# ─── Conit IDP ───────────────────────────────────────────────
# Base URL used for server-side API calls (token resolution)
IDP_BASE_URL=https://imsidpdev.fidaride.com/
# Base URL the browser is redirected to (may differ in split-DNS setups)
IDP_CLIENT_REDIRECT_URL=https://imsidpdev.fidaride.com/
MY_CLIENT_ID=your-portal-app-client-id
MY_CLIENT_SECRET=your-portal-app-client-secret

# Set to true in dev to skip IDP and use a fake SUPER_ADMIN session
DEV_BYPASS_IDP=false

# ─── Session ─────────────────────────────────────────────────
# Signed httpOnly cookie holding portal session (name can be customized).
SESSION_COOKIE_NAME=tms_portal_sess
# Optional; defaults to MY_CLIENT_SECRET if unset (prefer a dedicated secret in production).
# SESSION_SIGNING_SECRET=
INACTIVITY_TIMEOUT_MINUTES=2
IDP_RECHECK_TIMEOUT_MINUTES=5

# Server-side fetches to backends (dashboard health); abort after this many ms (default 8000).
# BACKEND_FETCH_TIMEOUT_MS=8000

# ─── GD Backend (Global Definitions) ────────────────────────
GD_BACKEND_BASE_URL=https://gdapidev.fidaride.com/
GD_BACKEND_PROFILE_PATH=/api/v1/me
# When true, send x-access-key to GD and omit legacy x-user-id/x-user-guid.
GD_USE_X_ACCESS_KEY=false

# ─── Core Backend (Operations) ──────────────────────────────
CORE_BACKEND_BASE_URL=https://tmsapidev.fidaride.com/
CORE_BACKEND_PROFILE_PATH=/api/v1/me
# When true, send x-access-key to Core and omit legacy x-user-id/x-user-guid.
CORE_USE_X_ACCESS_KEY=false

# ─── Notification Backend ───────────────────────────────────
NOTIFICATION_BACKEND_BASE_URL=https://ntfapidev.fidaride.com/
NOTIFICATION_BACKEND_PROFILE_PATH=/api/v1/me
# When true, send x-access-key to Notification and omit legacy x-user-id/x-user-guid.
NOTIFICATION_USE_X_ACCESS_KEY=false

# ─── DataGateway instances (DP_HexaBackend-API) ─────────────
GD_GATEWAY_BASE_URL=http://localhost:5100/
CORE_GATEWAY_BASE_URL=http://localhost:5400/
NOTIFICATION_GATEWAY_BASE_URL=http://localhost:5300/
